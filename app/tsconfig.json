{
	"include": ["**/*.js", "**/*.ts", "**/*.tsx"],
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"lib": ["ES2024", "DOM"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"pretty": true,
		"target": "esnext"
	}
}
