{
	"name": "ms-bot",
	"description": "A private Discord Bot for MS Gaming",
	"author": "DTrombett <d@trombett.org>",
	"homepage": "https://github.com/DTrombett/ms-bot#readme",
	"license": "MIT",
	"private": true,
	"type": "module",
	"version": "1.0.0",
	"keywords": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DTrombett/ms-bot.git"
	},
	"bugs": {
		"url": "https://github.com/DTrombett/ms-bot/issues"
	},
	"scripts": {
		"build": "node --enable-source-maps src/build/index.ts",
		"deploy": "npm run build && wrangler deploy",
		"dev": "wrangler dev --test-scheduled",
		"lint": "eslint --flag unstable_native_nodejs_ts_config src --fix",
		"test": "npm run build && tsc && eslint --flag unstable_native_nodejs_ts_config src",
		"types": "wrangler types && node src/patchTypes.ts"
	},
	"dependencies": {
		"@cloudflare/playwright": "^1.3.0",
		"@discordjs/rest": "^2.6.1",
		"bufferutil": "^4.1.0",
		"cloudflare": "^7.0.0",
		"discord-api-types": "^0.38.49",
		"entities": "^8.0.0",
		"esbuild": "^0.28.1",
		"fontkit": "^2.0.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"temporal-polyfill": "^1.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tsconfig/recommended": "^1.0.13",
		"@tsconfig/strictest": "^2.0.8",
		"@types/fontkit": "^2.0.9",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.7.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"wrangler": "^4.110.0"
	},
	"allowScripts": {
		"bufferutil@4.1.0": true,
		"esbuild@0.28.1": true,
		"sharp@0.34.5": true,
		"workerd@1.20260708.1": true
	}
}
