{
	"name": "ms-bot",
	"description": "A private Discord Bot for MS Gaming",
	"author": "DTrombett <d@trombett.org>",
	"homepage": "https://github.com/DTrombett/ms-bot#readme",
	"license": "MIT",
	"private": true,
	"type": "module",
	"version": "1.0.0",
	"keywords": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DTrombett/ms-bot.git"
	},
	"bugs": {
		"url": "https://github.com/DTrombett/ms-bot/issues"
	},
	"scripts": {
		"build": "node --enable-source-maps src/build.ts",
		"deploy": "npm run build && wrangler deploy",
		"dev": "wrangler dev --test-scheduled",
		"lint": "eslint --flag unstable_native_nodejs_ts_config src --fix",
		"prepare": "node src/prepare.ts",
		"test": "npm run build && tsc && eslint --flag unstable_native_nodejs_ts_config src",
		"types": "wrangler types && node src/patchTypes.ts"
	},
	"dependencies": {
		"@cloudflare/playwright": "^1.2.0",
		"@discordjs/rest": "^2.6.1",
		"@discordjs/ws": "^2.0.4",
		"bufferutil": "^4.1.0",
		"cloudflare": "^5.2.0",
		"discord-api-types": "^0.38.44",
		"entities": "^8.0.0",
		"esbuild": "^0.28.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"temporal-polyfill": "^0.3.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tsconfig/recommended": "^1.0.13",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.2.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"wrangler": "^4.80.0"
	}
}
