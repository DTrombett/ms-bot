{
	"include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"lib": ["ES2023", "DOM"],
		"module": "es6",
		"moduleResolution": "bundler",
		"noEmit": true,
		"pretty": true,
		"target": "es2023"
	}
}
